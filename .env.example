# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Your Telegram chat ID (bot only responds to this user)
OWNER_CHAT_ID=

# Path to SQLite database (default: ~/.conductor-telegram/conductor-telegram.db)
# This path is shared between the bot and MCP server instances
DB_PATH=~/.conductor-telegram/conductor-telegram.db

# Conductor workspaces directory (default: ~/conductor/workspaces)
CONDUCTOR_WORKSPACES_DIR=~/conductor/workspaces

# Conductor repos directory (default: ~/conductor/repos)
CONDUCTOR_REPOS_DIR=~/conductor/repos

# Optional default launch agent/model for /run (defaults to claude + Conductor's default model)
TELEGRAM_DEFAULT_AGENT_TYPE=claude
TELEGRAM_DEFAULT_MODEL=

# Optional review agent/model for /review (defaults to codex if Conductor already has Codex sessions)
TELEGRAM_REVIEW_AGENT_TYPE=codex
TELEGRAM_REVIEW_MODEL=gpt-5.4
