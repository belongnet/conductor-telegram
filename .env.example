# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Your Telegram chat ID (bot only responds to this user/group).
# Set to 0 temporarily to use /start or /setup for guided ID discovery.
OWNER_CHAT_ID=

# Your Telegram user ID (required for forum/supergroup mode so the bot
# only responds to you, not other group members). Optional in private chat mode.
OWNER_USER_ID=

# Path to SQLite database (default: ~/.conductor-telegram/conductor-telegram.db)
# This path is shared between the bot and MCP server instances
DB_PATH=~/.conductor-telegram/conductor-telegram.db

# Conductor workspaces directory (default: ~/conductor/workspaces)
CONDUCTOR_WORKSPACES_DIR=~/conductor/workspaces

# Conductor repos directory (default: ~/conductor/repos)
CONDUCTOR_REPOS_DIR=~/conductor/repos

# Optional default launch agent/model for /run (defaults to claude + Conductor's default model)
TELEGRAM_DEFAULT_AGENT_TYPE=claude
TELEGRAM_DEFAULT_MODEL=

# Optional review agent/model overrides for /review.
# Leave unset to keep the automatic fallback to Codex only when it is already available.
TELEGRAM_REVIEW_AGENT_TYPE=
TELEGRAM_REVIEW_MODEL=
